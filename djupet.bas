10 REM DJUPET - LEVEL GENERATOR TEST FOR LUXOR ABC80
20 RANDOMIZE
30 GOSUB 1000
40 GOSUB 3000
45 GOSUB 4200
50 GOSUB 4500
55 GOSUB 5000
60 END

1000 REM GENERATE A LEVEL USING ROOM DATA ONLY
1001 PRINT "Startar..."
1010 N%=6
1020 IF D%=0 THEN DIM P%(N%),Q%(N%),U%(N%),V%(N%),Z%(N%,N%):D%=1
1030 FOR A%=1 TO N%
1040 FOR B%=1 TO N%
1050 Z%(A%,B%)=0
1060 NEXT B%
1070 NEXT A%
1080 U%(1)=6+INT(RND(1)*6)
1090 V%(1)=5+INT(RND(1)*5)
1100 P%(1)=2+INT(RND(1)*(30-U%(1)))
1110 Q%(1)=2+INT(RND(1)*(23-V%(1)))
1120 FOR K%=2 TO N%
1130 L%=0
1140 FOR D%=1 TO 200
1150 B%=1+INT(RND(1)*(K%-1))
1160 U%(K%)=6+INT(RND(1)*6)
1170 V%(K%)=5+INT(RND(1)*5)
1180 C%=1+INT(RND(1)*4)
1190 IF C%=1 THEN X%=P%(B%)+U%(B%)-1:Y%=Q%(B%)-V%(K%)+2+INT(RND(1)*(V%(B%)+V%(K%)-3))
1200 IF C%=2 THEN X%=P%(B%)-U%(K%)+1:Y%=Q%(B%)-V%(K%)+2+INT(RND(1)*(V%(B%)+V%(K%)-3))
1210 IF C%=3 THEN X%=P%(B%)-U%(K%)+2+INT(RND(1)*(U%(B%)+U%(K%)-3)):Y%=Q%(B%)+V%(B%)-1
1220 IF C%=4 THEN X%=P%(B%)-U%(K%)+2+INT(RND(1)*(U%(B%)+U%(K%)-3)):Y%=Q%(B%)-V%(K%)+1
1230 IF (X%<2) OR (Y%<2) OR (X%+U%(K%)-1>30) OR (Y%+V%(K%)-1>23) THEN 1331
1240 IF (C%=1) OR (C%=2) THEN F%=Q%(B%)+1:G%=Q%(B%)+V%(B%)-2:H%=Y%+1:I%=Y%+V%(K%)-2
1250 IF (C%=3) OR (C%=4) THEN F%=P%(B%)+1:G%=P%(B%)+U%(B%)-2:H%=X%+1:I%=X%+U%(K%)-2
1260 IF F%<H% THEN F%=H%
1270 IF G%>I% THEN G%=I%
1280 IF G%-F%+1<3 THEN 1331
1290 M%=0
1291 FOR E%=1 TO K%-1
1300 R%=P%(E%):S%=Q%(E%):T%=R%+U%(E%)-1:O%=S%+V%(E%)-1
1310 W%=X%+U%(K%)-1:J%=Y%+V%(K%)-1
1320 IF (X%<T%) AND (W%>R%) AND (Y%<O%) AND (J%>S%) THEN M%=1
1325 NEXT E%
1326 IF M%=1 THEN 1331
1327 P%(K%)=X%:Q%(K%)=Y%
1328 A%=B%:B%=K%:GOSUB 1700
1329 L%=1
1330 GOTO 1340
1331 NEXT D%
1332 IF L%=0 THEN GOTO 1000
1340 NEXT K%
1410 E%=1
1420 F%=N%
1440 RETURN

1700 REM OPEN DOOR BETWEEN ROOMS A AND B
1710 Z%(A%,B%)=1
1720 Z%(B%,A%)=1
1730 RETURN

3000 REM DRAW LEVEL ROOM BY ROOM
3010 PRINT CHR$(12)
3020 PRINT CUR(23,39);
3040 FOR K%=1 TO N%
3050 C%=P%(K%):M%=Q%(K%):W%=U%(K%):H%=V%(K%)
3060 Y%=M%:GOSUB 3600
3070 Y%=M%+H%-1:GOSUB 3600
3080 X%=C%:GOSUB 3800
3090 X%=C%+W%-1:GOSUB 3800
3160 NEXT K%
3170 FOR A%=1 TO N%-1
3180 FOR B%=A%+1 TO N%
3190 IF Z%(A%,B%)=0 THEN 3240
3200 IF (P%(A%)+U%(A%)-1=P%(B%)) OR (P%(B%)+U%(B%)-1=P%(A%)) THEN GOSUB 3400
3210 IF (Q%(A%)+V%(A%)-1=Q%(B%)) OR (Q%(B%)+V%(B%)-1=Q%(A%)) THEN GOSUB 3500
3240 NEXT B%
3250 NEXT A%
3260 X%=P%(E%)+INT(U%(E%)/2):Y%=Q%(E%)+INT(V%(E%)/2)
3270 O%=Y%-1:I%=INT(O%/8):T%=31744+(I%*40)+((O%-(I%*8))*128)+(X%-1):POKE T%,70
3280 X%=P%(F%)+INT(U%(F%)/2):Y%=Q%(F%)+INT(V%(F%)/2)
3290 O%=Y%-1:I%=INT(O%/8):T%=31744+(I%*40)+((O%-(I%*8))*128)+(X%-1):POKE T%,69
3300 RETURN

3400 REM DRAW DOOR IN V WALL
3410 IF P%(A%)<P%(B%) THEN X%=P%(B%) ELSE X%=P%(A%)
3420 J%=Q%(A%)+1:K%=Q%(A%)+V%(A%)-2
3430 L%=Q%(B%)+1:M%=Q%(B%)+V%(B%)-2
3440 IF J%<L% THEN J%=L%
3450 IF K%>M% THEN K%=M%
3460 IF K%-J%+1<3 THEN RETURN
3470 Y%=J%+INT((K%-J%)/2)
3480 GOSUB 3980
3490 RETURN

3500 REM DRAW DOOR IN H WALL
3510 IF Q%(A%)<Q%(B%) THEN Y%=Q%(B%) ELSE Y%=Q%(A%)
3520 J%=P%(A%)+1:K%=P%(A%)+U%(A%)-2
3530 L%=P%(B%)+1:M%=P%(B%)+U%(B%)-2
3540 IF J%<L% THEN J%=L%
3550 IF K%>M% THEN K%=M%
3560 IF K%-J%+1<3 THEN RETURN
3570 X%=J%+INT((K%-J%)/2)
3580 GOSUB 3900
3590 RETURN

3600 REM DRAW ONE H WALL (X FROM C%..C%+W%-1 AT Y%)
3610 R%=Y%-1
3620 A%=INT(R%/8)
3630 B%=R%-(A%*8)
3640 T%=31744+(A%*40)+(B%*128)+(C%-1)
3650 POKE T%,43
3660 FOR I%=1 TO W%-2
3670 POKE T%+I%,45
3680 NEXT I%
3690 POKE T%+W%-1,43
3700 RETURN

3800 REM DRAW ONE V WALL (Y FROM M%+1..M%+H%-2 AT X%)
3810 FOR I%=M%+1 TO M%+H%-2
3820 R%=I%-1
3830 A%=INT(R%/8)
3840 B%=R%-(A%*8)
3850 T%=31744+(A%*40)+(B%*128)+(X%-1)
3860 POKE T%,33
3870 NEXT I%
3880 RETURN

3900 REM DRAW H + + CENTERED ON X%,Y%
3910 O%=Y%-1
3920 I%=INT(O%/8)
3930 T%=31744+(I%*40)+((O%-(I%*8))*128)+(X%-2)
3940 POKE T%,43
3950 POKE T%+1,32
3960 POKE T%+2,43
3970 RETURN

3980 REM DRAW V + + CENTERED ON X%,Y%
3990 O%=Y%-2
4000 I%=INT(O%/8)
4010 T%=31744+(I%*40)+((O%-(I%*8))*128)+(X%-1)
4020 POKE T%,43
4030 O%=Y%-1
4040 I%=INT(O%/8)
4050 T%=31744+(I%*40)+((O%-(I%*8))*128)+(X%-1)
4060 POKE T%,32
4070 O%=Y%
4080 I%=INT(O%/8)
4090 T%=31744+(I%*40)+((O%-(I%*8))*128)+(X%-1)
4100 POKE T%,43
4110 RETURN

4200 REM DRAW STATUS PANEL (RIGHT SIDE)
4210 FOR Y%=0 TO 23
4220 PRINT CUR(Y%,30)CHR$(151);
4230 NEXT Y%
4240 FOR Y%=62 TO 79
4250 SETDOT 0,Y%
4260 SETDOT 71,Y%
4270 NEXT Y%
4280 FOR X%=0 TO 71
4290 SETDOT X%,62
4300 SETDOT X%,79
4310 NEXT X%
4320 PRINT CUR(1,32)"STATUS";
4330 PRINT CUR(3,32)"HP";
4340 PRINT CUR(4,32)"XP";
4350 PRINT CUR(6,32)"GOLD";
4355 GOSUB 4370
4360 RETURN

4370 REM DRAW INVENTORY PANEL (SLOTS 1..0)
4380 PRINT CUR(8,32)"INV";
4390 FOR S%=1 TO 10
4400 R%=8+S%
4410 IF S%=10 THEN N$="0" ELSE N$=CHR$(48+S%)
4420 PRINT CUR(R%,32)CHR$(135)N$": "CHR$(151);
4430 NEXT S%
4440 RETURN

4500 REM GENERATE RANDOM ITEMS IN ROOMS
4510 C$="o":P%=50:GOSUB 4700
4520 C$="q":P%=30:GOSUB 4700
4530 C$="*":P%=80:GOSUB 4700
4540 C$="I":P%=80:GOSUB 4700
4550 C$="d":P%=80:GOSUB 4700
4560 C$="t":P%=20:GOSUB 4700
4570 C$="j":P%=5:GOSUB 4700
4580 C$="k":P%=2:GOSUB 4700
4590 C$="O":P%=20:GOSUB 4700
4600 C$="0":P%=5:GOSUB 4700
4610 G%=INT(RND(1)*5)
4620 C$="."
4630 FOR A%=1 TO G%
4640 R%=1+INT(RND(1)*N%)
4650 GOSUB 4800
4660 NEXT A%
4670 RETURN

4700 REM PLACE ONE ITEM C$ IN ROOM R% WITH CHANCE P%
4710 IF INT(RND(1)*100)+1>P% THEN RETURN
4720 R%=1+INT(RND(1)*N%)
4730 GOSUB 4800
4740 RETURN

4800 REM PLACE ITEM C$ ON EMPTY FLOOR IN ROOM R%
4810 FOR S%=1 TO 20
4820 X%=P%(R%)+1+INT(RND(1)*(U%(R%)-2))
4830 Y%=Q%(R%)+1+INT(RND(1)*(V%(R%)-2))
4840 GOSUB 9000
4850 IF PEEK(T%)<>32 THEN 4870
4860 POKE T%,ASC(C$):RETURN
4870 NEXT S%
4880 RETURN

5000 REM PLAYER CONTROL LOOP (A WITH E,S,D,X)
5010 X%=P%(E%)+INT(U%(E%)/2)
5020 Y%=Q%(E%)+INT(V%(E%)/2)
5030 GOSUB 9000
5040 B%=PEEK(T%)
5050 POKE T%,93
5060 GET K$
5070 IF K$="" THEN 5060
5080 J%=X%:K%=Y%
5085 C%=X%:M%=Y%
5086 IF (K$="P") OR (K$="p") THEN GOSUB 7200:GOTO 5060
5090 IF (K$="E") OR (K$="e") THEN M%=Y%-1
5100 IF (K$="X") OR (K$="x") THEN M%=Y%+1
5110 IF (K$="S") OR (K$="s") THEN C%=X%-1
5120 IF (K$="D") OR (K$="d") THEN C%=X%+1
5130 IF (C%=X%) AND (M%=Y%) THEN 5060
5140 IF (C%<1) OR (C%>30) OR (M%<1) OR (M%>24) THEN 5060
5150 POKE T%,B%
5160 X%=C%:Y%=M%
5170 GOSUB 9000
5180 V%=PEEK(T%)
5190 IF (V%=33) OR (V%=43) OR (V%=45) THEN X%=J%:Y%=K%:GOSUB 9000:POKE T%,93:GOTO 5060
5200 B%=V%
5210 POKE T%,93
5220 GOTO 5060

7200 REM PICK UP ITEM UNDER PLAYER INTO FIRST FREE INVENTORY SLOT
7210 IF (B%=111) OR (B%=113) OR (B%=42) OR (B%=73) OR (B%=100) THEN 7230
7215 IF (B%=106) OR (B%=107) OR (B%=79) OR (B%=48) OR (B%=116) THEN 7230
7220 RETURN
7230 C%=X%:M%=Y%
7235 X%=36
7240 FOR S%=1 TO 10
7250 Y%=9+S%
7260 GOSUB 9000
7270 IF PEEK(T%)<>32 THEN 7310
7280 POKE T%,B%
7290 B%=32
7300 X%=C%:Y%=M%:GOSUB 9000:POKE T%,93
7305 RETURN
7310 NEXT S%
7320 X%=C%:Y%=M%
7330 RETURN

9000 REM CALC SCREEN ADDRESS T% FROM X%,Y%
9010 O%=Y%-1
9020 I%=INT(O%/8)
9030 T%=31744+(I%*40)+((O%-(I%*8))*128)+(X%-1)
9040 RETURN
